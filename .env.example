# Required
TARGET_WALLET=0xTARGET_WALLET_TO_COPY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
RPC_URL=https://YOUR_ENDPOINT_NAME.quiknode.pro/YOUR_KEY

# Optional geo token (if provided by Polymarket for your account/region)
POLYMARKET_GEO_TOKEN=

# Trading
COPY_SELLS=true
POSITION_MULTIPLIER=0.1
MAX_TRADE_SIZE=100
MIN_TRADE_SIZE=1
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=FOK

# Filters
# Minimum USDC size of the target's trade to copy (skips dust/fragments)
MIN_COPY_USDC=10
# Skip trades where target's entry price is outside this range (filters cheap hedges)
MIN_COPY_PRICE=0
MAX_COPY_PRICE=1
# Comma-separated slug substrings to exclude (e.g. "updown-5m" skips 5-min BTC markets)
EXCLUDED_SLUG_PATTERNS=

# Run until first SELL is copied, then exit (for validation)
EXIT_AFTER_FIRST_SELL_COPY=false

# Risk (0 disables the cap)
MAX_SESSION_NOTIONAL=0
MAX_PER_MARKET_NOTIONAL=0

# Monitoring
USE_WEBSOCKET=true
USE_USER_CHANNEL=false
POLL_INTERVAL=2000
WS_ASSET_IDS=
WS_MARKET_IDS=

# Optional gas floor overrides for Polygon approval/order txs
MIN_PRIORITY_FEE_GWEI=30
MIN_MAX_FEE_GWEI=60
